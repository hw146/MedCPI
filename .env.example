# Optional environment overrides for the public MedCPI release.

MEDCPI_PROJECT_ROOT=/path/to/MedCPI

# Raw data
MEDCPI_MIMIC3_DIR=/path/to/mimic3
MEDCPI_MIMIC4_DIR=/path/to/mimic4

# External assets
MEDCPI_UMLS_ROOT=/path/to/umls
MEDCPI_RXNORM_ROOT=/path/to/rxnorm
MEDCPI_MODEL_CACHE_ROOT=/path/to/hf-cache

# Optional output override
MEDCPI_OUTPUT_ROOT=/path/to/MedCPI/outputs

# LLM-backed schema induction
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5
MEDCPI_ENCODER_MODEL=cambridgeltl/SapBERT-from-PubMedBERT-fulltext
